{
  "manifest_version": 3,
  "name": "JobLink",
  "version": "1.0.0",
  "description": "Scrape job postings from LinkedIn and Indeed, review them in a side panel, and save to Google Drive.",
  "permissions": [
    "storage",
    "identity",
    "sidePanel",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://linkedin.com/*",
    "https://*.linkedin.com/*",
    "*://indeed.com/*",
    "*://*.indeed.com/*",
    "<all_urls>"
  ],
  "oauth2": {
    "client_id": "750335831511-buksrfnh5406q0rg28bkh7epba11pipn.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/drive.file",
      "https://www.googleapis.com/auth/drive.metadata.readonly",
      "https://www.googleapis.com/auth/drive.readonly",
      "https://www.googleapis.com/auth/drive",
      "https://www.googleapis.com/auth/userinfo.email",
      "https://www.googleapis.com/auth/documents"
    ]
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["https://linkedin.com/*", "https://*.linkedin.com/*"],
      "js": ["content-scripts/linkedin.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.indeed.com/*"],
      "js": ["content-scripts/indeed.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "exclude_matches": [
        "https://linkedin.com/*",
        "https://*.linkedin.com/*",
        "*://indeed.com/*",
        "*://*.indeed.com/*"
      ],
      "js": ["content-scripts/generic.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["dashboard/dashboard.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_title": "JobLink",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
